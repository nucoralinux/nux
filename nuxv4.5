def repo_index_path(repo_name):
    return f"{INDEX_CACHE_DIR}/{repo_name}.json"

def repo_getir(repo_name=None):
    if repo_name:
        cache_path = Path(repo_index_path(repo_name))
    else:
        repos = aktif_repolar()
        if not repos:
            return None
        cache_path = Path(repo_index_path(repos[0]["name"]))

    if cache_path.exists():
        age = datetime.now().timestamp() - cache_path.stat().st_mtime
        if age < 3600:
            try:
                with open(cache_path) as f:
                    return json.load(f)
            except Exception:
                pass
    return None

def repo_getir_birlesik():
    merged = {"packages": {}, "package_count": 0, "version_count": 0}
    for repo in aktif_repolar():
        index = repo_getir(repo["name"])
        if not index:
            continue
        for name, pdata in index.get("packages", {}).items():
            if name not in merged["packages"]:
                merged["packages"][name] = pdata
                merged["packages"][name]["_repo"] = repo["name"]
                merged["packages"][name]["_repo_url"] = repo["url"]
            else:
                existing_repo_priority = 0
                for r in aktif_repolar():
                    if r["name"] == merged["packages"][name].get("_repo"):
                        existing_repo_priority = r.get("priority", 0)
                        break
                if repo.get("priority", 0) > existing_repo_priority:
                    merged["packages"][name] = pdata
                    merged["packages"][name]["_repo"] = repo["name"]
                    merged["packages"][name]["_repo_url"] = repo["url"]
    merged["package_count"] = len(merged["packages"])
    return merged

def update():
    bilgi(tr("repo_updating"))
    repos = aktif_repolar()
    if not repos:
        repos = DEFAULT_REPOS["repos"]
        repos_kaydet(repos)

    toplam = 0
    for repo in repos:
        repo_url = repo["url"].rstrip("/")
        index_url = f"{repo_url}/index.json"
        cache_path = repo_index_path(repo["name"])

        try:
            req = urllib.request.Request(index_url, headers={
                "Accept-Encoding": "gzip",
                "User-Agent": f"nux/{CLIENT_VERSION}"
            })
            with urllib.request.urlopen(req, timeout=60) as response:
                data = response.read()
                if response.headers.get("Content-Encoding") == "gzip":
                    data = gzip.decompress(data)
                ensure_dirs()
                with open(cache_path, "wb") as f:
                    f.write(data)
                index = json.loads(data)
                count = index.get("package_count", 0)
                toplam += count
                basari(f"{tr('repo_updated')}: {repo['name']} ({count} {tr('packages')})")
        except urllib.error.URLError as e:
            uyari(f"{repo['name']}: {e}")
        except Exception as e:
            uyari(f"{repo['name']}: {e}")

    return 0

