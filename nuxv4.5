# ══════════════════════════════════════════════════════════════════

def run_pkg_script(script, pkg_name, script_name, args=None, meta=None, fatal=True):
    if not script.exists(): return True
    args = args or []
    env = cmd_env()
    env["DPKG_MAINTSCRIPT_PACKAGE"] = pkg_name
    env["DPKG_MAINTSCRIPT_NAME"] = script_name
    env["DPKG_ADMINDIR"] = "/var/lib/dpkg"
    if meta and meta.get("architecture"):
        env["DPKG_MAINTSCRIPT_ARCH"] = meta["architecture"]
    try:
        result = subprocess.run(
            ["bash", str(script)] + args,
            capture_output=True, text=True,
            cwd=str(script.parent), env=env, timeout=300
        )
    except Exception as e:
        if fatal: hata(f"{script_name} ({pkg_name}): {e}")
        return False
    if result.returncode != 0:
        msg = result.stderr.strip()[:150] or f"exit {result.returncode}"
        if fatal: hata(f"{script_name} ({pkg_name}): {msg}")
        return False
    return True

