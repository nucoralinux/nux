def local_install(dosya_yolu):
    if root_kontrol(): return 1
    path = Path(dosya_yolu)
    if not path.exists(): return hata(f"{dosya_yolu}")
    if not dosya_yolu.endswith(".nux"): return hata(".nux")

    try: acquire_lock()
    except LockError as e: return hata(str(e))

    try:
        db = db_yukle()
        transaction = []

        with tarfile.open(str(path), "r:*") as tar:
            meta = json.loads(tar.extractfile(tar.getmember("metadata.json")).read().decode("utf-8"))

        name = meta.get("name", path.stem)
        version = meta.get("version", "?")
        cls = meta.get("class", "app")

        print(f"\n{C}╔{'═'*58}╗{RE}")
        print(f"{C}║{RE}  {W}{tr('local_install')}{RE}")
        print(f"{C}╠{'═'*58}╣{RE}")
        print(f"{C}║{RE}  {G}✓{RE} {C}{name:28}{RE} {Y}{version:16}{RE} {class_badge(cls)}")
        print(f"{C}║{RE}  {DIM}{dosya_yolu}{RE}")
        print(f"{C}╚{'═'*58}╝{RE}\n")

        if not onayla(tr("install_confirm")): return 0

        cache_path = Path(CACHE_DIR) / path.name
        shutil.copy2(path, cache_path)
        meta["sha256"] = sha256_hash(str(cache_path))
        meta["filename"] = f"local/{path.name}"
        meta["managed_by"] = "nux"

        if _pkg_kur(name, meta, db, transaction, auto_installed=False):
            basari(f"✓ {name} {tr('install_done')}")
            history_yaz("LOCAL_INSTALL", name, version)
            db_kaydet(db)
            sistem_guncelle()
            return 0
        else:
            return hata(f"{name} {tr('install_fail')}")
    finally:
        release_lock()

