# ══════════════════════════════════════════════════════════════════

def provides(name):
    index = repo_getir_birlesik()
    db = db_yukle()
    if not index: update(); index = repo_getir_birlesik()

    found = []
    for pn, pd in index.get("packages", {}).items():
        latest = pd.get("latest")
        if not latest: continue
        info = pd["versions"][latest]
        if name in info.get("provides", []):
            found.append((pn, info.get("version", "?")))
    for pn, pm in db.items():
        if name in pm.get("provides", []) and pn not in [f[0] for f in found]:
            found.append((pn, pm.get("version", "?")))

    if not found:
        print(f"\n  {Y}'{name}' not provided by any package{RE}\n")
        return 1

    print(f"\n  {W}'{name}' provided by:{RE}")
    for pn, ver in found:
        cls = paket_sinifi(db.get(pn, {}))
        installed = f" {G}[installed]{RE}" if pn in db else ""
        print(f"    → {C}{pn}{RE} {Y}{ver}{RE} {class_badge(cls)}{installed}")
    print()
    return 0

