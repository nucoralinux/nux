def _script_store(name): return Path(SCRIPTS_ROOT) / name

def _scripts_kaydet(name, scripts_dir):
    dst = _script_store(name)
    shutil.rmtree(dst, ignore_errors=True)
    if scripts_dir.exists():
        shutil.copytree(scripts_dir, dst, symlinks=True)

def _install_one_file(src, dest, files_base, tar_members):
    rel_path = str(src.relative_to(files_base))
    member_key = f"files/{rel_path}"
    if src.is_dir():
        dest.mkdir(parents=True, exist_ok=True)
        member = tar_members.get(member_key)
        if member:
            try: os.chmod(dest, member.mode)
            except Exception: pass
        return None
    dest.parent.mkdir(parents=True, exist_ok=True)
    if src.is_symlink():
        target = os.readlink(src)
        if dest.exists() or dest.is_symlink():
            try:
                if dest.is_dir() and not dest.is_symlink(): shutil.rmtree(dest)
                else: dest.unlink()
            except Exception: pass
        os.symlink(target, dest)
        return str(dest)
    if not src.is_file(): return None
    shutil.copy2(src, dest)
    member = tar_members.get(member_key)
    if member:
        try: os.chmod(dest, member.mode)
        except Exception: pass
    return str(dest)

