def remove(pkgs, purge=False):
    if root_kontrol(): return 1
    if not pkgs: return hata("nux remove <paket>")

    try: acquire_lock()
    except LockError as e: return hata(str(e))

    try:
        db = db_yukle()
        pins = pin_yukle()
        silinecek = []
        for name in pkgs:
            if name not in db: uyari(f"{tr('not_installed')}: {name}"); continue
            if name in pins: uyari(f"{tr('pinned_pkg')}: {name}"); continue
            if name in PROTECTED_PACKAGES or db[name].get("protected"): uyari(f"{tr('protected_pkg')}: {name}"); continue
            silinecek.append(name)
        if not silinecek: return 0

        silinecek_set = set(silinecek)
        for pn, pd in db.items():
            if pn in silinecek_set: continue
            for dep in pd.get("depends", []):
                if not dep_karsilaniyor_mu_haric(dep, db, silinecek_set):
                    return hata(f"'{pn}' bozulur: {dep}")

        print(f"\n{R}╔{'═'*58}╗{RE}")
        print(f"{R}║{RE}  {W}{tr('remove_pkgs')} ({len(silinecek)}){RE}")
        print(f"{R}╠{'═'*58}╣{RE}")
        for p in silinecek:
            print(f"{R}║{RE}  {R}✗{RE} {p} {Y}{db[p].get('version','?')}{RE} {class_badge(paket_sinifi(db[p]))}")
        print(f"{R}╚{'═'*58}╝{RE}\n")

        if not onayla(tr("remove_confirm")): return 0

        for name in silinecek:
            meta = db[name]
            sd = _script_store(name)
            pre = sd / "pre-remove.sh"
            if pre.exists():
                run_pkg_script(pre, name, "prerm", ["remove"], meta=meta, fatal=False)
            for f_str in meta.get("files", []):
                try:
                    p = Path(f_str)
                    if not p.exists() and not p.is_symlink(): continue
                    if not purge and any(f_str.endswith(c) for c in meta.get("conffiles", [])): continue
                    p.unlink(missing_ok=True)
                    try: p.parent.rmdir()
                    except OSError: pass
                except Exception: pass
            post = sd / "post-remove.sh"
            if post.exists():
                run_pkg_script(post, name, "postrm", ["purge" if purge else "remove"], meta=meta, fatal=False)
            shutil.rmtree(sd, ignore_errors=True)
            del db[name]
            db_kaydet(db)
            history_yaz("REMOVE", name, meta.get("version"))
            basari(f"{tr('remove_done')}: {name}")

        sistem_guncelle()
        return 0
    finally:
        release_lock()

