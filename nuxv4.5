def adim_goster(adim, toplam, mesaj, durum="active"):
    style = CFG.get("install_animation", "stepped")
    if style == "stepped":
        if durum == "done":
            icon = f"{G}✅{RE}"
        elif durum == "active":
            icon = f"{C}●{RE}"
        else:
            icon = f"{DIM}○{RE}"
        print(f"  {icon} {mesaj}")
    elif style == "classic":
        print(f"  {DIM}[{adim}/{toplam}]{RE} {C}{mesaj}{RE}")
    else:
        print(f"  {Y}[{adim}/{toplam}]{RE} {mesaj}")

