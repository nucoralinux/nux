def main():
    global QUIET, ASSUME_YES, VERBOSE, CFG

    args = sys.argv[1:]
    if "-qq" in args: QUIET = True; args.remove("-qq")
    elif "-q" in args or "--quiet" in args:
        QUIET = True; args = [a for a in args if a not in ("-q","--quiet")]
    if "-y" in args or "--yes" in args:
        ASSUME_YES = True; args = [a for a in args if a not in ("-y","--yes")]
    if "-v" in args or "--verbose" in args:
        VERBOSE = True; args = [a for a in args if a not in ("-v","--verbose")]

    if not args: yardim(); return 0

    cmd = args[0]
    params = args[1:]

    komutlar = {
        "install":        lambda: install(params),
        "remove":         lambda: remove(params),
        "purge":          lambda: remove(params, purge=True),
        "reinstall":      lambda: reinstall(params),
        "upgrade":        lambda: upgrade("apps-only" if "--apps-only" in params else ("full" if "--full" in params else "normal")),
        "update":         lambda: update(),
        "dry-run":        lambda: install(params, dry_run=True),
        "local-install":  lambda: local_install(params[0]) if params else hata("File?"),
        "import":         lambda: import_list(params[0]) if params else hata("File?"),
        "export":         lambda: export_packages(),
        "search":         lambda: search(params[0]) if params else hata("Query?"),
        "info":           lambda: info_cmd(params[0]) if params else hata("Package?"),
        "show":           lambda: info_cmd(params[0]) if params else hata("Package?"),
        "list":           lambda: listele("--upgradeable" in params or "-u" in params),
        "depends":        lambda: depends_cmd(params[0]) if params else hata("Package?"),
        "rdepends":       lambda: depends_cmd(params[0], reverse=True) if params else hata("Package?"),
        "why":            lambda: why(params[0]) if params else hata("Package?"),
        "tree":           lambda: tree(params[0]) if params else hata("Package?"),
        "owns":           lambda: owns(params[0]) if params else hata("File?"),
        "provides":       lambda: provides(params[0]) if params else hata("Name?"),
        "list-all":       lambda: list_all(),
        "policy":         lambda: policy(params[0]) if params else hata("Package?"),
        "verify":         lambda: verify(params or None),
        "repair":         lambda: repair(),
        "autoremove":     lambda: autoremove(),
        "clean":          lambda: clean(),
        "cache-info":     lambda: cache_info(),
        "doctor":         lambda: doctor(),
        "db-clean":       lambda: db_clean(),
        "scan-system":    lambda: scan_system(),
        "sync-system":    lambda: sync_system(),
        "adopt":          lambda: adopt(params) if params else hata("Package?"),
        "size":           lambda: size_report(),
        "top":            lambda: size_report(),
        "count":          lambda: count(),
        "config":         lambda: config_menu(),
        "mark-auto":      lambda: mark_auto(params) if params else hata("Package?"),
        "mark-manual":    lambda: mark_manual(params) if params else hata("Package?"),
        "pin":            lambda: pin_ekle(params) if params else hata("Package?"),
        "unpin":          lambda: pin_kaldir(params) if params else hata("Package?"),
        "hold":           lambda: pin_ekle(params) if params else hata("Package?"),
        "unhold":         lambda: pin_kaldir(params) if params else hata("Package?"),
        "history":        lambda: history_goster(),
        "rollback":       lambda: rollback(int(params[0])) if params and params[0].isdigit() else rollback(),
        "snapshot":       lambda: (
            snapshot_create(params[1] if len(params) > 1 else None) if params and params[0] == "create"
            else snapshot_list() if params and params[0] == "list"
            else snapshot_restore(params[1]) if params and params[0] == "restore" and len(params) > 1
            else hata("snapshot create|list|restore")
        ),
        "repo":           lambda: (
            repo_list() if params and params[0] == "list"
            else repo_add(params[1], params[2], int(params[3]) if len(params) > 3 else 50) if params and params[0] == "add" and len(params) >= 3
            else repo_remove(params[1]) if params and params[0] == "remove" and len(params) >= 2
            else repo_enable(params[1]) if params and params[0] == "enable" and len(params) >= 2
            else repo_disable(params[1]) if params and params[0] == "disable" and len(params) >= 2
            else hata("repo list|add|remove|enable|disable")
        ),
        "server-status":  lambda: server_status(),
        "mirror-test":    lambda: mirror_test(),
        "log":            lambda: history_goster(),
        "help":           lambda: yardim(),
        "--help":         lambda: yardim(),
        "-h":             lambda: yardim(),
        "version":        lambda: print(renkli(f"nux {CLIENT_VERSION}", G)),
        "--version":      lambda: print(renkli(f"nux {CLIENT_VERSION}", G)),
    }

    if cmd in komutlar:
        try:
            return komutlar[cmd]() or 0
        except KeyboardInterrupt:
            print(renkli("\n[!] Cancelled.", Y))
            return 130
        except Exception as e:
            if VERBOSE:
                import traceback
                print(traceback.format_exc())
            return hata(f"{e}")

    hata(f"Unknown: {cmd}")
    print(f"\n  {C}nux help{RE}\n")
    return 1

