                     if gecerli_paket_adi(pn) and name in [dep_temizle(x) for x in pd.get("depends", [])]]
        if not bagimlilar: bilgi(f"{name}: no rdeps."); return 0
        print(f"\n{name} rdepends:\n")
        for p in sorted(bagimlilar):
            print(f"   {C}{p}{RE} {class_badge(paket_sinifi(db.get(p, {})))}")
        print()
    return 0

