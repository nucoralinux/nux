# SCAN-SYSTEM / SYNC-SYSTEM / ADOPT
# ══════════════════════════════════════════════════════════════════

def scan_system():
    if root_kontrol(): return 1
    with Spinner(tr("scan_system")):
        try:
            result = subprocess.run(
                ["dpkg-query","-W","-f=${Package}\t${Version}\t${binary:Summary}\n"],
                capture_output=True, text=True, timeout=30, env=cmd_env()
            )
        except Exception as e:
            return hata(str(e))

    db = db_yukle()
    added = 0
    for line in result.stdout.splitlines():
        parts = line.split("\t", 2)
        if len(parts) < 3: continue
        name, version, summary = parts
        if not gecerli_paket_adi(name): continue
        if name in db: continue
        db[name] = {
            "name": name,
            "version": version,
            "description": summary.strip(),
            "class": "base",
            "managed_by": "system",
            "installed_at": datetime.now().isoformat(),
            "auto_installed": True,
            "install_reason": "system",
        }
        added += 1
    db_kaydet(db)
    basari(f"{added} {tr('packages')}")
    return 0

def sync_system():
    if root_kontrol(): return 1
    with Spinner(tr("sync_system")):
        try:
            result = subprocess.run(
                ["dpkg-query","-W","-f=${Package}\t${Version}\n"],
                capture_output=True, text=True, timeout=30, env=cmd_env()
            )
        except Exception as e:
            return hata(str(e))

    sys_pkgs = {}
    for line in result.stdout.splitlines():
        parts = line.split("\t", 1)
        if len(parts) == 2 and gecerli_paket_adi(parts[0]):
            sys_pkgs[parts[0]] = parts[1]

    db = db_yukle()
    updated = removed = added = 0

    for name in list(db.keys()):
        if paket_yoneticisi(db[name]) != "system": continue
        if name not in sys_pkgs:
            del db[name]
            removed += 1
        elif db[name].get("version") != sys_pkgs[name]:
            db[name]["version"] = sys_pkgs[name]
            updated += 1

    for name, ver in sys_pkgs.items():
        if name not in db:
            db[name] = {
                "name": name, "version": ver,
                "class": "base", "managed_by": "system",
                "auto_installed": True, "install_reason": "system",
            }
            added += 1

    db_kaydet(db)
    basari(f"+{added} / ~{updated} / -{removed}")
    return 0

def adopt(pkgs):
    if root_kontrol(): return 1
    db = db_yukle()
    for name in pkgs:
        if not _dpkg_kurulu_mu(name):
            uyari(f"{tr('not_installed')}: {name}")
            continue
        try:
            ver = subprocess.run(
                ["dpkg-query","-W","-f=${Version}","--",name],
                capture_output=True, text=True, timeout=5, env=cmd_env()
            ).stdout.strip()
        except Exception:
            ver = "0"
        db[name] = {
            "name": name, "version": ver,
            "class": "base", "managed_by": "system",
            "auto_installed": False, "install_reason": "manual",
            "installed_at": datetime.now().isoformat(),
        }
        basari(f"{tr('adopted')}: {name}")
    db_kaydet(db)
    return 0

