def install(pkgs, dry_run=False):
    if root_kontrol() and not dry_run: return 1
    if not pkgs: return hata("nux install <paket>")

    if len(pkgs) == 1 and (pkgs[0].endswith(".nux") or os.path.isfile(pkgs[0])):
        return local_install(pkgs[0])

    if not dry_run:
        try: acquire_lock()
        except LockError as e: return hata(str(e))

    try:
        db = db_yukle()
        index = repo_getir_birlesik()
        if not index or not index.get("packages"):
            update()
            index = repo_getir_birlesik()
        if not index:
            return hata("Repo erişilemiyor.")

        repo_pkgs = index.get("packages", {})
        eksik = []
        for pkg in pkgs:
            if pkg in db:
                bilgi(f"{tr('already_installed')}: {pkg}")
                continue
            if pkg not in repo_pkgs and not sistemde_paket_var(pkg):
                eksik.append(pkg)

        if eksik:
            for pkg in eksik:
                _oneri_goster(pkg, index)
            return 1

        yedek = db_yedekle() if not dry_run else None
        transaction = []

        try:
            resolver = DependencyResolver(index, db)
            kurulacak, bilgiler = resolver.coz(pkgs)
        except ValueError as e:
            return hata(str(e))

        yeni = [p for p in kurulacak if p not in db]
        if not yeni:
            bilgi(tr("all_uptodate"))
            return 0

        manuel_kokler = set()
        for pkg in pkgs:
            provider = resolver.repo_provider(pkg) or pkg
            manuel_kokler.add(provider)

        toplam_boyut = sum(int(bilgiler[p].get("installed_size", 0) or 0) for p in yeni)
        indirme = sum(int(bilgiler[p].get("size", 0) or 0) for p in yeni)

        print(f"\n{C}╔{'═'*58}╗{RE}")
        print(f"{C}║{RE}  {W}{tr('install_pkgs')}{RE}")
        print(f"{C}╠{'═'*58}╣{RE}")

        for p in yeni:
            info = bilgiler[p]
            cls = info.get("class", "base" if p not in manuel_kokler else "app")
            badge = class_badge(cls)
            repo_name = info.get("_repo", "")
            auto = f" {DIM}[auto]{RE}" if p not in manuel_kokler else ""
            print(f"{C}║{RE}  {G}✓{RE} {C}{p:28}{RE} {Y}{info.get('version','?'):16}{RE} {badge} ← {DIM}{repo_name}{RE}{auto}")

        print(f"{C}╠{'═'*58}╣{RE}")
        print(f"{C}║{RE}  {W}{tr('total')}:{RE} {len(yeni)} {tr('packages')}")
        print(f"{C}║{RE}  {W}{tr('installed_size')}:{RE} {boyut_formatla(toplam_boyut)}")
        print(f"{C}║{RE}  {W}{tr('download_size')}:{RE} {boyut_formatla(indirme)}")
        print(f"{C}║{RE}  {W}{tr('est_time')}:{RE} {sure_tahmin(indirme)}")
        print(f"{C}╚{'═'*58}╝{RE}\n")

        if dry_run:
            bilgi("Dry-run.")
            return 0

        if not onayla(tr("install_confirm")):
            bilgi(tr("cancelled"))
            return 0

        baslangic = time.monotonic()
        ok = 0
        hatalar_list = []

        for i, name in enumerate(yeni, 1):
            print(f"\n{DIM}{'─'*58}{RE}")
            info = bilgiler[name]
            auto_flag = name not in manuel_kokler

            eksik_deps = [d for d in info.get("depends", []) if not dep_karsilaniyor_mu(d, db)]
            if eksik_deps:
                uyari(f"Skip: {name} ({', '.join(eksik_deps[:3])})")
                hatalar_list.append(name)
                continue

            if _pkg_kur(name, info, db, transaction, len(yeni), i, auto_installed=auto_flag):
                basari(f"✓ {name} {tr('install_done')}")
                history_yaz("INSTALL", name, info.get("version"))
                db_kaydet(db)
                ok += 1
            else:
                uyari(f"✗ {name} {tr('install_fail')}")
                hatalar_list.append(name)

        if ok > 0:
            with Spinner(tr("system_updating")):
                sistem_guncelle()

        sure = time.monotonic() - baslangic
        print()
        if ok == len(yeni):
            basari(f"{ok}/{len(yeni)} {tr('packages')} ✓")
            if yedek: Path(yedek).unlink(missing_ok=True)
            return 0
        else:
            uyari(f"{ok}/{len(yeni)}")
            if hatalar_list:
                print(renkli(f"  {', '.join(hatalar_list)}", R))
            if onayla(tr("rollback_ask")):
                rollback_transaction(transaction, db)
            return 1
    finally:
        if not dry_run:
            release_lock()

