def clean():
    if root_kontrol(): return 1
    dosyalar = list(Path(CACHE_DIR).rglob("*.nux")) + list(Path(CACHE_DIR).rglob("*.partial"))
    if not dosyalar: bilgi(tr("cache_clean")); return 0
    toplam = sum(f.stat().st_size for f in dosyalar if f.exists())
    print(f"\n{len(dosyalar)} files, {boyut_formatla(toplam)}")
    if not onayla("Clean?"): return 0
    for f in dosyalar: f.unlink(missing_ok=True)
    basari(tr("cache_cleaned"))
    return 0

def autoremove():
    if root_kontrol(): return 1
    db = db_yukle()
    if not db: bilgi(tr("no_packages")); return 0
    pins = set(pin_yukle())
    has_auto = any("auto_installed" in m for m in db.values())
    if not has_auto: return 0

    korunanlar = {n for n, m in db.items() if n in PROTECTED_PACKAGES or m.get("protected")}
    manuel = {n for n, m in db.items() if not m.get("auto_installed")}
    kokler = manuel | pins | korunanlar
    ulasilan = set()
    kuyruk = list(kokler)
    while kuyruk:
        pkg = kuyruk.pop(0)
        if pkg in ulasilan or pkg not in db: continue
        ulasilan.add(pkg)
        for dep in db[pkg].get("depends", []):
            provider = secili_kurulu_provider(dep, db)
            if provider and provider not in ulasilan:
                kuyruk.append(provider)

    orphan = sorted([
        n for n, m in db.items()
        if m.get("auto_installed") and n not in ulasilan
        and n not in pins and n not in korunanlar
        and paket_yoneticisi(m) == "nux"
    ])
    if not orphan: bilgi("No orphans."); return 0
    print(f"\nOrphan ({len(orphan)}):")
    for p in orphan:
        print(f"  {Y}✗{RE} {p} {class_badge(paket_sinifi(db[p]))}")
    print()
    if not onayla("Remove?"): return 0
    return remove(orphan)

def verify(pkgs=None):
    db = db_yukle()
    kontrol = pkgs if pkgs else [n for n in db if gecerli_paket_adi(n) and paket_yoneticisi(db[n]) == "nux"]
    if not kontrol: bilgi(tr("no_packages")); return 0
    hatali = []
    for name in kontrol:
        if name not in db: continue
        for dosya, beklenen in db[name].get("sha256_files", {}).items():
            p = Path(dosya)
            if not p.exists() or (not p.is_symlink() and sha256_hash(dosya) != beklenen):
                hatali.append(name)
                break
    if not hatali: basari(tr("healthy")); return 0
    print(f"\n{R}{len(hatali)} broken.{RE}")
    if onayla("Reinstall?"): return reinstall(list(set(hatali)))
    return 1

def repair():
    if root_kontrol(): return 1
    db = db_yukle()
    if not db: bilgi(tr("no_packages")); return 0
    with Spinner(tr("scan_system")):
        hatali = []
        for name, meta in db.items():
            if paket_yoneticisi(meta) != "nux": continue
            for dosya, beklenen in meta.get("sha256_files", {}).items():
                p = Path(dosya)
                if not p.exists() or (not p.is_symlink() and sha256_hash(dosya) != beklenen):
                    hatali.append(name); break
    if not hatali: basari(tr("all_healthy")); return 0
    print(f"\n{R}{len(hatali)} broken.{RE}")
    if onayla("Reinstall?"): return reinstall(hatali)
    return 1

def db_clean():
    if root_kontrol(): return 1
    db = db_yukle()
    if not db: bilgi(tr("db_empty")); return 0
    invalid = gecersiz_db_kayitlari(db)
    if not invalid: basari(tr("db_clean")); return 0
    print(f"\n{R}{len(invalid)} invalid records.{RE}")
    if not onayla(f"Clean {len(invalid)}?"): return 0
    db_yedekle()
    for n in invalid: del db[n]
    db_kaydet(db)
    basari(f"{len(invalid)} cleaned.")
    return 0

