def history_yaz(action, pkg, details=""):
    ensure_dirs()
    entry = {"timestamp": datetime.now().isoformat(), "action": action, "package": pkg, "details": details}
    try:
        history = []
        if Path(HISTORY_FILE).exists():
            with open(HISTORY_FILE) as f: history = json.load(f)
        history.append(entry)
        with open(HISTORY_FILE, "w") as f:
            json.dump(history, f, indent=2, ensure_ascii=False)
    except Exception:
        pass

def history_goster(limit=20):
    if not Path(HISTORY_FILE).exists(): bilgi(tr("no_history")); return 0
    with open(HISTORY_FILE) as f: history = json.load(f)
    if not history: bilgi(tr("no_history")); return 0
    print(f"\nHistory (last {limit}):\n")
    for i, e in enumerate(history[-limit:], len(history) - min(limit, len(history)) + 1):
        ts = e.get("timestamp","?")[:19]
        action = e.get("action","?")
        pkg = e.get("package","?")
        color = G if action == "INSTALL" else (R if action == "REMOVE" else C)
        print(f"  {DIM}#{i:3}{RE} [{ts}] {color}{action:12}{RE} {C}{pkg}{RE}")
    print(f"\n  {DIM}Rollback: nux rollback <#>{RE}\n")
    return 0

def rollback(target_id=None):
    if root_kontrol(): return 1
    if not Path(HISTORY_FILE).exists(): bilgi(tr("no_history")); return 0
    with open(HISTORY_FILE) as f: history = json.load(f)
    if not history: bilgi(tr("no_history")); return 0
    entry = history[target_id - 1] if target_id and 1 <= target_id <= len(history) else history[-1]
    action, pkg = entry.get("action"), entry.get("package")
    bilgi(f"Rollback: {action} {pkg}")
    if not onayla("Continue?"): return 0
    if action == "INSTALL": result = remove([pkg])
    elif action == "REMOVE": result = install([pkg])
    else: uyari("Not supported."); return 1
    if result == 0:
        if not target_id:
            history.pop()
            with open(HISTORY_FILE, "w") as f: json.dump(history, f, indent=2, ensure_ascii=False)
        basari(tr("rollback_done"))
    return result

