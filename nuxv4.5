# DOCTOR
# ══════════════════════════════════════════════════════════════════

def doctor():
    print(f"\n{C}╔{'═'*50}╗{RE}")
    print(f"{C}║{RE}  {W}{tr('doctor_title')}{RE}")
    print(f"{C}╚{'═'*50}╝{RE}\n")

    checks = []
    db = db_yukle()

    invalid = gecersiz_db_kayitlari(db)
    nux_count = sum(1 for m in db.values() if paket_yoneticisi(m) == "nux")
    sys_count = sum(1 for m in db.values() if paket_yoneticisi(m) == "system")
    checks.append((not invalid, f"{tr('doctor_db')}: {len(db)} ({nux_count} nux, {sys_count} system)"))

    for repo in aktif_repolar()[:3]:
        try:
            start = time.monotonic()
            url = f"{repo['url'].rstrip('/')}/index.json"
            urllib.request.urlopen(urllib.request.Request(url), timeout=10)
            ms = (time.monotonic() - start) * 1000
            checks.append((True, f"{tr('doctor_repo')}: {repo['name']} ({ms:.0f}ms)"))
        except Exception:
            checks.append((False, f"{tr('doctor_repo')}: {repo['name']} FAIL"))

    cache_files = list(Path(CACHE_DIR).rglob("*.nux"))
    cache_size = sum(f.stat().st_size for f in cache_files if f.exists())
    checks.append((True, f"{tr('doctor_cache')}: {len(cache_files)} / {boyut_formatla(cache_size)}"))

    if Path(LOCK_FILE).exists():
        pid = Path(LOCK_FILE).read_text().strip()
        if pid and Path(f"/proc/{pid}").exists():
            checks.append((False, f"{tr('doctor_lock')}: PID {pid}"))
        else:
            checks.append((None, f"{tr('doctor_lock')}: stale"))
    else:
        checks.append((True, f"{tr('doctor_lock')}: OK"))

    cc = {"app": 0, "base": 0, "tool": 0}
    for m in db.values():
        cc[paket_sinifi(m)] = cc.get(paket_sinifi(m), 0) + 1
    checks.append((True, f"{tr('doctor_class')}: {cc.get('app',0)} app, {cc.get('base',0)} base, {cc.get('tool',0)} tool"))

    for status, msg in checks:
        icon = f"{G}✓{RE}" if status is True else (f"{R}✗{RE}" if status is False else f"{Y}!{RE}")
        print(f"  {icon} {msg}")

    print()
    issues = sum(1 for s, _ in checks if s is False)
    if issues == 0: basari(tr("doctor_healthy"))
    else: uyari(f"{issues} {tr('doctor_issues')}")
    print()
    return 0

