def repo_add(name, url, priority=50):
    repos = repos_yukle()
    for r in repos:
        if r["name"] == name:
            return hata(f"{tr('repo_exists')}: {name}")

    bilgi(f"{name}: {url}")
    try:
        req = urllib.request.Request(f"{url.rstrip('/')}/index.json",
                                     headers={"User-Agent": f"nux/{CLIENT_VERSION}"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
            count = data.get("package_count", 0)
        basari(f"{tr('connection_ok')}: {count} {tr('packages')}")
    except Exception as e:
        uyari(f"{tr('connection_fail')}: {e}")
        if not onayla("Add anyway?"): return 1

    repos.append({
        "name": name, "url": url,
        "enabled": True, "priority": priority,
        "description": "",
    })
    repos_kaydet(repos)
    basari(f"{tr('repo_added')}: {name}")
    return 0

def repo_remove(name):
    repos = repos_yukle()
    new_repos = [r for r in repos if r["name"] != name]
    if len(new_repos) == len(repos):
        return hata(f"{tr('repo_not_found')}: {name}")
    repos_kaydet(new_repos)
    Path(repo_index_path(name)).unlink(missing_ok=True)
    basari(f"{tr('repo_removed')}: {name}")
    return 0

def repo_enable(name):
    repos = repos_yukle()
    for r in repos:
        if r["name"] == name:
            r["enabled"] = True
            repos_kaydet(repos)
            basari(f"{tr('repo_enabled')}: {name}")
            return 0
    return hata(f"{tr('repo_not_found')}: {name}")

def repo_disable(name):
    repos = repos_yukle()
    for r in repos:
        if r["name"] == name:
            r["enabled"] = False
            repos_kaydet(repos)
            basari(f"{tr('repo_disabled')}: {name}")
            return 0
    return hata(f"{tr('repo_not_found')}: {name}")

