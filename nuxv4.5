# BENZERLİK ÖNERİSİ
# ══════════════════════════════════════════════════════════════════

def benzer_paket_oner(sorgu, index, limit=5):
    paketler = index.get("packages", {})
    skorlar = []
    s = sorgu.lower()
    for ad in paketler:
        a = ad.lower()
        if a.startswith(s): skor = 50
        elif s in a: skor = 30
        else:
            idx = 0
            skor = 0
            for ch in s:
                pos = a.find(ch, idx)
                if pos == -1: skor = 0; break
                idx = pos + 1
                skor = 10
        if skor > 0:
            skorlar.append((skor, ad))
    skorlar.sort(key=lambda x: (-x[0], x[1]))
    return [ad for _, ad in skorlar[:limit]]

def _oneri_goster(sorgu, index):
    adaylar = benzer_paket_oner(sorgu, index)
    if not adaylar:
        print(renkli(f"\n  '{sorgu}' {tr('pkg_not_found')}.\n", Y))
        return
    print(renkli(f"\n  '{sorgu}' {tr('pkg_not_found')}:\n", Y))
    for i, ad in enumerate(adaylar, 1):
        print(f"    {C}{i}.{RE} {G}{ad}{RE}")
    print(f"\n  {C}nux install <paket>{RE}\n")

