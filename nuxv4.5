def owns(filepath):
    db = db_yukle()
    filepath = os.path.realpath(filepath)
    found = []
    for name, meta in db.items():
        if filepath in meta.get("files", []):
            found.append(name)
    if not found:
        print(f"\n  {Y}{filepath}{RE}: no owner found\n")
        return 1
    print(f"\n  {W}{filepath}{RE}:")
    for name in found:
        cls = paket_sinifi(db[name])
        print(f"    → {C}{name}{RE} {class_badge(cls)}")
    print()
    return 0

