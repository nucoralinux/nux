def why(name):
    db = db_yukle()
    if name not in db: return hata(f"{tr('not_installed')}: {name}")
    meta = db[name]

    print(f"\n  {W}{name}{RE} {tr('why_installed')}:")
    print()

    if not meta.get("auto_installed"):
        print(f"    → {G}{tr('why_manual')}{RE}")
    else:
        print(f"    → {Y}{tr('why_auto')}{RE}")

    bagimlilar = []
    for pn, pd in db.items():
        if pn == name: continue
        if name in [dep_temizle(d) for d in pd.get("depends", [])]:
            bagimlilar.append(pn)

    if bagimlilar:
        print(f"\n    {C}{tr('why_depends')}:{RE}")
        for p in sorted(bagimlilar):
            print(f"      ├── {p} {class_badge(paket_sinifi(db.get(p, {})))}")

    print(f"\n    {DIM}Class: {paket_sinifi(meta)}{RE}")
    print(f"    {DIM}Managed by: {paket_yoneticisi(meta)}{RE}")
    print(f"    {DIM}Version: {meta.get('version', '?')}{RE}")
    if meta.get("_installed_from_repo"):
        print(f"    {DIM}Repo: {meta['_installed_from_repo']}{RE}")
    print()
    return 0

# ══════════════════════════════════════════════════════════════════
# TREE
# ══════════════════════════════════════════════════════════════════

def tree(name, max_depth=4):
    index = repo_getir_birlesik()
    db = db_yukle()
    if not index: update(); index = repo_getir_birlesik()

    resolver = DependencyResolver(index, db)
    info = resolver.get_package_info(name)
    if not info and name not in db:
        return hata(f"{tr('pkg_not_found')}: {name}")
    if not info: info = db.get(name, {})

    cls = info.get("class", paket_sinifi(db.get(name, {})))
    ver = info.get("version", db.get(name, {}).get("version", "?"))
    print(f"\n  {W}{name}{RE} {Y}{ver}{RE} {class_badge(cls)}")

    def _print(pkg_info, prefix="  ", depth=0, visited=None):
        if visited is None: visited = set()
        if depth >= max_depth: return
        deps = pkg_info.get("depends", [])
        for i, dep in enumerate(deps):
            dn = dep_temizle(dep)
            if not dn: continue
            is_last = (i == len(deps) - 1)
            conn = "└──" if is_last else "├──"
            child_pfx = "    " if is_last else "│   "
            if dn in db:
                st = f"{G}●{RE}"
                dc = paket_sinifi(db[dn])
            elif sistemde_paket_var(dn):
                st = f"{B}●{RE}"
                dc = "base"
            else:
                st = f"{R}○{RE}"
                dc = "?"
            badge = class_badge(dc) if dc != "?" else f"{DIM}[?]{RE}"
            if dn in visited:
                print(f"{prefix}{conn} {st} {dn} {badge} {DIM}(cycle){RE}")
                continue
            print(f"{prefix}{conn} {st} {dn} {badge}")
            visited.add(dn)
            di = resolver.get_package_info(dn)
            if not di and dn in db: di = db[dn]
            if di and depth < max_depth - 1:
                _print(di, prefix + child_pfx, depth + 1, visited)

    _print(info)
    print(f"\n  {DIM}● nux  ● system  ○ missing{RE}\n")
    return 0

