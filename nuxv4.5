def reinstall(pkgs):
    if root_kontrol(): return 1
    if not pkgs: return hata("nux reinstall <paket>")
    try: acquire_lock()
    except LockError as e: return hata(str(e))
    try:
        db = db_yukle()
        index = repo_getir_birlesik()
        if not index: update(); index = repo_getir_birlesik()
        transaction = []
        for name in pkgs:
            resolver = DependencyResolver(index, db)
            info = resolver.get_package_info(name)
            if not info: uyari(f"{tr('pkg_not_found')}: {name}"); continue
            if name in db:
                for f in db[name].get("files", []):
                    try:
                        if not any(str(f).endswith(c) for c in db[name].get("conffiles", [])):
                            Path(f).unlink(missing_ok=True)
                    except Exception: pass
            cache_p = Path(CACHE_DIR) / Path(info["filename"]).name
            cache_p.unlink(missing_ok=True)
            auto = db.get(name, {}).get("auto_installed", False)
            if _pkg_kur(name, info, db, transaction, auto_installed=auto):
                basari(f"✓ {name}"); history_yaz("REINSTALL", name, info.get("version")); db_kaydet(db)
            else: hata(f"{name}")
        sistem_guncelle()
        return 0
    finally:
        release_lock()

