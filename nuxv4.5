    bilgi(f"{len(packages)} {tr('exported')}")
    return 0

def import_list(dosya_yolu):
    if root_kontrol(): return 1
    path = Path(dosya_yolu)
    if not path.exists(): return hata(f"{dosya_yolu}")
    pkgs = []
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line and not line.startswith("#"):
                pkgs.append(line.split()[0])
    if not pkgs: return hata("No packages.")
    bilgi(f"{len(pkgs)} {tr('packages')}")
    return install(pkgs)

