def snapshot_create(name=None):
    if root_kontrol(): return 1
    ensure_dirs()
    db = db_yukle()
    if not name: name = datetime.now().strftime("snap_%Y%m%d_%H%M%S")
    snap_file = Path(SNAPSHOT_DIR) / f"{name}.json"
    if snap_file.exists(): return hata(f"exists: {name}")
    snapshot = {
        "name": name,
        "created_at": datetime.now().isoformat(),
        "nux_version": CLIENT_VERSION,
        "packages": {
            pkg: {"version": m.get("version","?"), "class": paket_sinifi(m), "managed_by": paket_yoneticisi(m)}
            for pkg, m in db.items() if gecerli_paket_adi(pkg) and paket_yoneticisi(m) == "nux"
        }
    }
    with open(snap_file, "w") as f:
        json.dump(snapshot, f, indent=2, ensure_ascii=False)
    basari(f"{tr('snapshot_created')}: {name} ({len(snapshot['packages'])} {tr('packages')})")
    return 0

def snapshot_list():
    ensure_dirs()
    snaps = sorted(Path(SNAPSHOT_DIR).glob("*.json"))
    if not snaps: bilgi(tr("no_snapshots")); return 0
    print()
    for sf in snaps:
        try:
            with open(sf) as f: data = json.load(f)
            print(f"  {C}{data.get('name', sf.stem):30}{RE} {DIM}{data.get('created_at','?')[:19]}{RE}  {W}{len(data.get('packages',{}))} pkg{RE}")
        except Exception:
            print(f"  {R}{sf.stem}{RE} {DIM}(corrupt){RE}")
    print()
    return 0

def snapshot_restore(name):
    if root_kontrol(): return 1
    sf = Path(SNAPSHOT_DIR) / f"{name}.json"
    if not sf.exists(): return hata(f"{name}")
    with open(sf) as f: snapshot = json.load(f)
    db = db_yukle()
    sp = snapshot.get("packages", {})
    to_install = [p for p in sp if p not in db]
    to_remove = [p for p in db if p not in sp and gecerli_paket_adi(p) and paket_yoneticisi(db[p]) == "nux"]

    if not to_install and not to_remove:
        bilgi("Same state."); return 0

    if to_install: print(f"\n  {G}Install:{RE} {len(to_install)}")
    if to_remove: print(f"  {R}Remove:{RE} {len(to_remove)}")
    if not onayla("Apply?"): return 0
    if to_install: install(to_install)
    if to_remove: remove(to_remove)
    basari(f"{tr('snapshot_restored')}: {name}")
    return 0

