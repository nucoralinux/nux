def config_yukle() -> Dict:
    try:
        with open(CONFIG_FILE) as f:
            cfg = json.load(f)
            merged = {**DEFAULT_CONFIG, **cfg}
            return merged
    except Exception:
        return DEFAULT_CONFIG.copy()

def config_kaydet(cfg: Dict):
    Path(CONFIG_DIR).mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2, ensure_ascii=False)

def repos_yukle() -> List[Dict]:
    try:
        with open(REPOS_FILE) as f:
            data = json.load(f)
            return data.get("repos", [])
    except Exception:
        return DEFAULT_REPOS["repos"].copy()

def repos_kaydet(repos: List[Dict]):
    Path(CONFIG_DIR).mkdir(parents=True, exist_ok=True)
    with open(REPOS_FILE, "w") as f:
        json.dump({"repos": repos}, f, indent=2, ensure_ascii=False)

def aktif_repolar() -> List[Dict]:
    repos = repos_yukle()
    aktif = [r for r in repos if r.get("enabled", True)]
    aktif.sort(key=lambda r: r.get("priority", 0), reverse=True)
    return aktif

