def server_status():
    for repo in aktif_repolar():
        try:
            start = time.monotonic()
            url = f"{repo['url'].rstrip('/')}/index.json"
            req = urllib.request.Request(url, headers={"User-Agent": f"nux/{CLIENT_VERSION}"})
            with urllib.request.urlopen(req, timeout=10) as r:
                data = json.loads(r.read())
            ms = (time.monotonic() - start) * 1000
            print(f"\n  {G}✓{RE} {C}{repo['name']}{RE}: {ms:.0f}ms, {data.get('package_count', 0)} pkgs")
        except Exception as e:
            print(f"\n  {R}✗{RE} {C}{repo['name']}{RE}: {e}")
    print()
    return 0

