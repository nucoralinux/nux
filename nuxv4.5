# UPGRADE — SADECE managed_by=nux VE class=app/tool
# ══════════════════════════════════════════════════════════════════

def upgrade(mode="normal"):
    if root_kontrol(): return 1
    try: acquire_lock()
    except LockError as e: return hata(str(e))

    try:
        db = db_yukle()
        index = repo_getir_birlesik()
        if not index or not index.get("packages"):
            update()
            index = repo_getir_birlesik()

        pins = pin_yukle()
        resolver = DependencyResolver(index, db)
        guncellenecek = []

        for name, meta in db.items():
            if name in pins: continue

            managed = paket_yoneticisi(meta)
            cls = paket_sinifi(meta)

            # SADECE nux tarafından yönetilen paketler
            if managed != "nux":
                continue

            # Mode kontrolü
            if mode == "apps-only" and cls not in ("app",):
                continue
            elif mode == "normal" and cls == "base":
                continue
            # mode == "full" ise hepsini al

            info = resolver.get_package_info(name)
            if info:
                mevcut = db_versiyon_kontrol(name, meta)
                yeni = info.get("version", "0")
                cmp = versiyon_karsilastir(yeni, mevcut)
                if cmp < 0:
                    uyari(f"Downgrade engellendi: {name} ({mevcut} > {yeni})")
                    continue
                if cmp > 0:
                    guncellenecek.append((name, mevcut, yeni, info))

        if not guncellenecek:
            basari(tr("all_uptodate"))
            return 0

        print(f"\n{C}╔{'═'*58}╗{RE}")
        print(f"{C}║{RE}  {W}{tr('upgradable_pkgs')} ({len(guncellenecek)}){RE}")
        print(f"{C}╠{'═'*58}╣{RE}")
        for name, eski, yeni, info in guncellenecek:
            cls = info.get("class", paket_sinifi(db.get(name, {})))
            repo_name = info.get("_repo", "")
            print(f"{C}║{RE}  {C}{name:28}{RE} {Y}{eski:12}{RE} → {G}{yeni}{RE} {class_badge(cls)} ← {DIM}{repo_name}{RE}")
        print(f"{C}╚{'═'*58}╝{RE}\n")

        if not onayla(tr("upgrade_confirm")): return 0

        nux_updated = False
        for name, eski, yeni, info in guncellenecek:
            bilgi(f"{tr('upgrading')}: {name}")
            eski_meta = db[name]
            for f in eski_meta.get("files", []):
                try:
                    if not any(str(f).endswith(c) for c in eski_meta.get("conffiles", [])):
                        Path(f).unlink(missing_ok=True)
                except Exception: pass

            transaction = []
            if _pkg_kur(name, info, db, transaction):
                basari(f"{tr('upgrade_done')}: {name}")
                history_yaz("UPGRADE", name, f"{eski} → {yeni}")
                db_kaydet(db)
                if name == "nux": nux_updated = True
            else:
                uyari(f"{tr('upgrade_fail')}: {name}")

        sistem_guncelle()

        if nux_updated:
            basari("nux updated. Restarting...")
            release_lock()
            nux_path = shutil.which("nux") or NUX_BIN
            os.execv(nux_path, ["nux"] + sys.argv[1:])

        return 0
    finally:
        release_lock()

