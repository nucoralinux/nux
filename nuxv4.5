def gecerli_paket_adi(name): return bool(name and PKG_NAME_RE.fullmatch(name))
def gecersiz_db_kayitlari(db): return [n for n in db if not gecerli_paket_adi(n)]

def is_tool_package(name):
    if name in TOOL_PACKAGES: return True
    return any(name.startswith(p) for p in TOOL_PREFIXES)

def paket_sinifi(meta): return meta.get("class", "app")
def paket_yoneticisi(meta): return meta.get("managed_by", "nux")

def gecerli_versiyon(ver):
    return bool(ver and re.match(r'^[0-9]', ver))

def db_versiyon_kontrol(name, meta):
    ver = meta.get("version", "0")
    if not gecerli_versiyon(ver):
        try:
            result = subprocess.run(
                ["dpkg-query","-W","-f=${Version}","--",name],
                capture_output=True, text=True, timeout=5, env=cmd_env()
            )
            if result.returncode == 0 and result.stdout.strip():
                dpkg_ver = result.stdout.strip()
                if gecerli_versiyon(dpkg_ver):
                    meta["version"] = dpkg_ver
                    return dpkg_ver
        except Exception:
            pass
        return "0"
    return ver

