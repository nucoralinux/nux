def dep_temizle(dep):
    dep = dep.split("|", 1)[0].strip()
    dep = re.sub(r"\s*\(.*?\)", "", dep).strip()
    dep = re.sub(r"\s*\[.*?\]", "", dep).strip()
    dep = re.sub(r":[A-Za-z0-9_-]+$", "", dep).strip()
    return dep

def dep_alternatifleri(dep):
    sonuc = []
    for alt in dep.split("|"):
        alt = alt.strip()
        alt = re.sub(r"\s*\(.*?\)", "", alt).strip()
        alt = re.sub(r"\s*\[.*?\]", "", alt).strip()
        alt = re.sub(r":[A-Za-z0-9_-]+$", "", alt).strip()
        if alt and gecerli_paket_adi(alt):
            sonuc.append(alt)
    return sonuc

def bagimlilik_yoksay(name):
    if name in IGNORED_DEPS: return True
    return any(name.endswith(s) for s in IGNORED_DEP_SUFFIXES)

_dpkg_cache = {}

def _dpkg_kurulu_mu(name):
    if name in _dpkg_cache: return _dpkg_cache[name]
    try:
        result = subprocess.run(
            ["dpkg-query","-W","-f=${Status}","--",name],
            capture_output=True, text=True, timeout=5, env=cmd_env()
        )
        kurulu = result.returncode == 0 and "install ok installed" in result.stdout
        _dpkg_cache[name] = kurulu
        return kurulu
    except Exception:
        _dpkg_cache[name] = False
        return False

def _dpkg_provides_kontrol(name):
    try:
        result = subprocess.run(
            ["dpkg-query","-W","-f=${Package}\t${Provides}\t${Status}\n"],
            capture_output=True, text=True, timeout=10, env=cmd_env()
        )
        if result.returncode != 0: return False
        for line in result.stdout.splitlines():
            parts = line.strip().split("\t")
            if len(parts) < 3: continue
            if "install ok installed" not in parts[2]: continue
            if parts[1]:
                for prov in parts[1].split(","):
                    if prov.strip().split(" ",1)[0].strip() == name:
                        _dpkg_cache[name] = True
                        return True
        return False
    except Exception:
        return False

def sistemde_paket_var(name):
    if bagimlilik_yoksay(name): return True
    if shutil.which(name): return True
    if _dpkg_kurulu_mu(name): return True
    if not name.endswith("t64") and _dpkg_kurulu_mu(name + "t64"): return True
    if _dpkg_provides_kontrol(name): return True
    return False

def dep_karsilaniyor_mu(dep_expr, db):
    for alt in dep_alternatifleri(dep_expr):
        if bagimlilik_yoksay(alt): return True
        if alt in db: return True
        for pn, pm in db.items():
            if alt in pm.get("provides", []): return True
        if sistemde_paket_var(alt): return True
    name = dep_temizle(dep_expr)
    if name and bagimlilik_yoksay(name): return True
    if name and sistemde_paket_var(name): return True
    return False

def dep_karsilaniyor_mu_haric(dep_expr, db, haric):
    for alt in dep_alternatifleri(dep_expr):
        if bagimlilik_yoksay(alt): return True
        for pn, pm in db.items():
            if pn in haric: continue
            if pn == alt or alt in pm.get("provides", []): return True
        if sistemde_paket_var(alt): return True
    name = dep_temizle(dep_expr)
    if name and bagimlilik_yoksay(name): return True
    if name and sistemde_paket_var(name): return True
    return False

def secili_kurulu_provider(dep_expr, db):
    for alt in dep_alternatifleri(dep_expr):
        if alt in db: return alt
        for pn, pm in db.items():
            if alt in pm.get("provides", []): return pn
    return None

def cozum_mesaji_uret(name, gerekli=None):
    lines = []
    if gerekli:
        lines.append(f"{tr('dep_not_found')}: {name}")
        lines.append(f"    {gerekli}")
    else:
        lines.append(f"{tr('pkg_not_found')}: {name}")
    lines.append(f"\n  {Y}nux search {name}{RE}")
    return "\n".join(lines)

