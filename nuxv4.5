def versiyon_karsilastir(v1, v2):
    try:
        if subprocess.run(["dpkg","--compare-versions",v1,"lt",v2],
                         capture_output=True, env=cmd_env()).returncode == 0:
            return -1
        if subprocess.run(["dpkg","--compare-versions",v1,"gt",v2],
                         capture_output=True, env=cmd_env()).returncode == 0:
            return 1
        return 0
    except Exception:
        return -1 if v1 < v2 else (1 if v1 > v2 else 0)

