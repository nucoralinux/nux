# ══════════════════════════════════════════════════════════════════

def size_report():
    db = db_yukle()
    if not db: bilgi(tr("no_packages")); return 0
    siralama = []
    for name, meta in db.items():
        if not gecerli_paket_adi(name): continue
        if paket_yoneticisi(meta) != "nux": continue
        boyut = int(meta.get("installed_size", 0) or 0)
        siralama.append((name, boyut, meta.get("version", "?"), paket_sinifi(meta)))
    siralama.sort(key=lambda x: x[1], reverse=True)

    if not siralama: bilgi("No nux-managed packages."); return 0
    max_b = siralama[0][1] if siralama else 1

    print(f"\n{C}╔{'═'*58}╗{RE}")
    print(f"{C}║{RE}  {W}{tr('size_title')}{RE}")
    print(f"{C}╚{'═'*58}╝{RE}\n")

    for i, (name, boyut, ver, cls) in enumerate(siralama[:20], 1):
        bar_len = int((boyut / max_b) * 20) if max_b > 0 else 0
        bar = "█" * bar_len + "░" * (20 - bar_len)
        print(f"  {DIM}{i:2}.{RE} {C}{name:25}{RE} {G}{bar}{RE} {Y}{boyut_formatla(boyut):>10}{RE} {class_badge(cls)}")

    toplam = sum(b for _, b, _, _ in siralama)
    print(f"\n  {W}{tr('total')}:{RE} {Y}{boyut_formatla(toplam)}{RE} ({len(siralama)} {tr('packages')})\n")
    return 0

