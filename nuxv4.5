# PROGRESS BAR
# ══════════════════════════════════════════════════════════════════

class ProgressBar:
    def __init__(self, total, desc="", toplam_adim=1, mevcut_adim=1):
        self.total = total
        self.desc = desc
        self.toplam_adim = toplam_adim
        self.mevcut_adim = mevcut_adim
        self.downloaded = 0
        self._start = time.monotonic()
        self._last_time = self._start
        self._last_bytes = 0
        self._speed = 0.0
        self._style = CFG.get("progress_style", "detailed")

    def update(self, chunk):
        self.downloaded += len(chunk)
        now = time.monotonic()
        elapsed = now - self._last_time
        if elapsed >= 0.1:
            delta = self.downloaded - self._last_bytes
            speed = delta / elapsed / 1024 / 1024
            self._speed = speed if self._speed == 0 else 0.3 * speed + 0.7 * self._speed
            self._last_time = now
            self._last_bytes = self.downloaded
        self.draw()

    def draw(self):
        if self.total <= 0:
            return
        ratio = min(self.downloaded / self.total, 1.0)
        pct = int(ratio * 100)

        if self._style == "minimal":
            sys.stdout.write(f"\r  {C}[↓]{RE} {self.desc} {W}{pct}%{RE}  ")
        elif self._style == "simple":
            filled = int(30 * ratio)
            bar = "█" * filled + "░" * (30 - filled)
            sys.stdout.write(f"\r  {C}[↓]{RE} {self.desc} [{G}{bar}{RE}] {W}{pct}%{RE}  ")
        else:
            filled = int(35 * ratio)
            bar = "█" * filled + "░" * (35 - filled)
            mb_d = self.downloaded / 1024 / 1024
            mb_t = self.total / 1024 / 1024
            spd = f"{self._speed:.1f} MB/s" if self._speed > 0 else "..."
            remaining = ""
            if self._speed > 0:
                left = (self.total - self.downloaded) / (self._speed * 1024 * 1024)
                if left < 60:
                    remaining = f" ~{int(left)}s"
                else:
                    remaining = f" ~{int(left/60)}m"
            adim = f"{DIM}[{self.mevcut_adim}/{self.toplam_adim}]{RE} " if self.toplam_adim > 1 else ""
            sys.stdout.write(
                f"\r{adim}{C}[↓]{RE} {self.desc} "
                f"[{G}{bar}{RE}] {W}{pct}%{RE} "
                f"{DIM}{mb_d:.1f}/{mb_t:.1f}MB{RE} "
                f"{Y}{spd}{RE}{remaining}  "
            )
        sys.stdout.flush()

    def finish(self):
        elapsed = time.monotonic() - self._start
        mb = self.downloaded / 1024 / 1024
        spd = f"{mb/elapsed:.1f} MB/s" if elapsed > 0 else "?"
        sys.stdout.write(f"\r{G}[✓]{RE} {self.desc}  {W}{mb:.1f} MB{RE} {Y}{spd}{RE}      \n")
        sys.stdout.flush()

